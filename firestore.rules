rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ════════════════════════════════════════════════════

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    // Admin check: doc existence in /admins/{uid} (written only from Console).
    function isAdmin() {
      return isLoggedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Billing / status guard (updates) ────────────────
    // Returns true only when the incoming write does NOT change any
    // admin-controlled field inside profile.*.
    function billingUnchanged() {
      let oldP = resource.data.get('profile', {});
      let newP = request.resource.data.get('profile', {});
      return newP.get('plan',             oldP.get('plan', 'free'))          == oldP.get('plan', 'free')
          && newP.get('planId',           oldP.get('planId', ''))            == oldP.get('planId', '')
          && newP.get('planExpiry',       oldP.get('planExpiry', ''))        == oldP.get('planExpiry', '')
          && newP.get('status',           oldP.get('status', 'pending'))     == oldP.get('status', 'pending')
          && newP.get('rejectReason',     oldP.get('rejectReason', ''))      == oldP.get('rejectReason', '')
          && newP.get('trialExpiry',      oldP.get('trialExpiry', ''))       == oldP.get('trialExpiry', '')
          && newP.get('trialDays',        oldP.get('trialDays', 0))          == oldP.get('trialDays', 0)
          && newP.get('trialSuspended',   oldP.get('trialSuspended', false)) == oldP.get('trialSuspended', false)
          && newP.get('referredBy',       oldP.get('referredBy', ''))        == oldP.get('referredBy', '')
          && newP.get('payoutPaidAmount', oldP.get('payoutPaidAmount', 0))   == oldP.get('payoutPaidAmount', 0)
          && newP.get('refPaidCount',     oldP.get('refPaidCount', 0))       == oldP.get('refPaidCount', 0)
          && newP.get('refTotalCount',    oldP.get('refTotalCount', 0))      == oldP.get('refTotalCount', 0);
    }

    // ── proTrial guard (updates) ─────────────────────────
    // Protects appState.proTrial from server-side tampering.
    // Once proTrial is set (startedAt exists), the user may NOT modify it —
    // only admin can change it. This closes the localStorage/Firestore bypass
    // where a user could POST { appState: { proTrial: { expiry: "2099-01-01" } } }
    // directly to Firestore and gain permanent Pro access.
    //
    // Allowed cases:
    //   1. No proTrial in the existing doc AND no proTrial in the incoming write
    //      (neither side has it — unchanged).
    //   2. No proTrial in the existing doc AND the incoming write sets it for
    //      the first time (trial activation by the user is permitted once).
    //   3. proTrial already exists AND the incoming write leaves it identical
    //      (user is saving other appState fields, not touching proTrial).
    function proTrialUnchanged() {
      let oldAT = resource.data.get('appState', {});
      let newAT = request.resource.data.get('appState', {});
      let oldTrial = oldAT.get('proTrial', null);
      let newTrial = newAT.get('proTrial', null);

      // Case 1 & 2: no existing trial → allow (first activation or no trial).
      // Case 3: trial exists → new value must be identical (freeze it).
      return oldTrial == null
          || newTrial == oldTrial;
    }

    // ── Billing guard (create) ───────────────────────────
    // Users cannot self-approve their own account or self-grant a paid plan.
    function billingSafeOnCreate() {
      let p = request.resource.data.get('profile', {});
      return p.get('plan', 'free')            == 'free'
          && p.get('planId', '')              == ''
          && p.get('payoutPaidAmount', 0)     == 0
          && p.get('trialSuspended', false)   == false
          && (p.get('status', 'pending')      == 'pending'
           || p.get('status', 'approved')     == 'approved');
          // 'approved' is kept as a valid create-time status because the app
          // auto-approves on registration. If you want manual approval, change
          // this to: p.get('status', 'pending') == 'pending'
    }


    // ════════════════════════════════════════════════════
    //  COLLECTIONS
    // ════════════════════════════════════════════════════

    // ── Admin role collection ────────────────────────────
    // Readable only by the uid owner (so the app can confirm admin status).
    // Writable ONLY from Firebase Console — never from client SDKs.
    match /admins/{uid} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── User documents ───────────────────────────────────
    // Firestore evaluates rules in document order and grants on FIRST match.
    // Each operation is spelled out explicitly so an omnibus "write" rule can
    // never shadow the per-operation owner rules.
    match /users/{uid} {
      // Read: owner or admin
      allow read: if isOwner(uid) || isAdmin();

      // Create: owner only, with billing safety checks
      allow create: if isOwner(uid) && billingSafeOnCreate();

      // Update: owner (billing + proTrial fields frozen) OR admin (unrestricted)
      allow update: if isAdmin()
                 || (isOwner(uid) && billingUnchanged() && proTrialUnchanged());

      // Delete: admin only
      allow delete: if isAdmin();
    }

    // ── Plans ────────────────────────────────────────────
    // Any logged-in user can read available plans; only admin can write.
    match /plans/{planId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Config (UPI, free limits, feature flags) ─────────
    // Any logged-in user can read; only admin can write.
    match /config/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Payments ─────────────────────────────────────────
    match /payments/{payId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid      == request.auth.uid
        && request.resource.data.amount   is number
        && request.resource.data.amount   >  0
        && request.resource.data.status   == 'pending'
        && request.resource.data.keys().hasAll(['uid', 'planId', 'amount', 'status', 'createdAt'])
        // Verify the referenced plan actually exists
        && exists(/databases/$(database)/documents/plans/$(request.resource.data.planId));

      allow read:   if isLoggedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());

      allow update: if isAdmin();

      // Payments are immutable once created (no delete, no user update)
      allow delete: if false;
    }

    // ── Coupons ──────────────────────────────────────────
    // Any signed-in user can read (to validate at checkout).
    // Admin: full write access.
    // Normal user: may ONLY increment usedCount by exactly +1 on redemption.
    // NOTE: this update is still racy under high concurrency — two redemptions
    // can both read N and write N+1. For hard single-use guarantees, move
    // redemption into a Cloud Function with a Firestore transaction.
    match /coupons/{code} {
      allow read:          if isLoggedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || ( isLoggedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount'])
          && request.resource.data.usedCount is number
          && request.resource.data.usedCount == resource.data.get('usedCount', 0) + 1 );
    }

    // ── Coupon redemptions (audit log) ───────────────────
    match /coupon_redemptions/{redemptionId} {
      allow create: if isLoggedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll([
             'couponCode', 'uid', 'planId',
             'originalAmount', 'discountAmount', 'finalAmount',
             'createdAt'
           ])
        && request.resource.data.originalAmount is number
        && request.resource.data.originalAmount >  0
        && request.resource.data.discountAmount is number
        && request.resource.data.discountAmount >  0
        && request.resource.data.discountAmount <  request.resource.data.originalAmount
        && request.resource.data.finalAmount    is number
        && request.resource.data.finalAmount    >  0
        && request.resource.data.originalAmount
           == request.resource.data.discountAmount + request.resource.data.finalAmount
        // Ensure the coupon code actually exists and is enabled
        && exists(/databases/$(database)/documents/coupons/$(request.resource.data.couponCode));

      allow read:   if isLoggedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Feature / content requests ───────────────────────
    // Bind uid field on create to the authenticated user's UID.
    match /requests/{docId} {
      allow create: if isLoggedIn()
        && (!('uid' in request.resource.data)
         || request.resource.data.uid == request.auth.uid);
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ── Referrals ────────────────────────────────────────
    // Users can read their own referral stats; only admin can write.
    match /referrals/{uid} {
      allow read:  if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ── Payouts ──────────────────────────────────────────
    // Admin-only read and write.
    match /payouts/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Admin audit log ──────────────────────────────────
    // Written by adminLog() on every admin action. Admin-only, append-only:
    // entries can be created and read by admins but never edited or deleted.
    match /admin_logs/{logId} {
      allow create:         if isAdmin();
      allow read:           if isAdmin();
      allow update, delete: if false;
    }

    // ── Default deny ─────────────────────────────────────
    // Catch-all: any path not matched above is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
